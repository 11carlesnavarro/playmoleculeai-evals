<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ b.eval_set }} — {{ b.run_id }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  th, td { border: 1px solid #ddd; padding: 0.5rem 0.75rem; text-align: left; }
  th { background: #f4f4f4; }
  code { background: #f0f0f0; padding: 0.1em 0.3em; border-radius: 3px; }
  h1 { border-bottom: 2px solid #1a1a1a; padding-bottom: 0.25rem; }
  h2 { margin-top: 2rem; }
  .ok { color: #1a7a1a; font-weight: 600; }
  .bad { color: #c00; font-weight: 600; }
  .dim { color: #888; }
</style>
</head>
<body>
<h1>{{ b.eval_set }}</h1>
<p>
  <strong>Run id:</strong> <code>{{ b.run_id }}</code><br>
  <strong>Total cost:</strong> ${{ "%.4f"|format(b.total_cost_usd or 0) }}<br>
  {% if b.aborted_over_budget %}<strong class="bad">Aborted over budget</strong>{% endif %}
</p>

<h2>Models</h2>
<table>
  <tr>
    <th>Model</th><th>Cases ✓/total</th><th>Assertions</th>
    <th>Rubric pass</th><th>Rubric mean</th><th>Cost</th>
  </tr>
  {% for m in b.models|sort(attribute='assertion_pass_rate', reverse=True) %}
  <tr>
    <td><code>{{ m.model }}</code></td>
    <td>{{ m.cases_completed }} / {{ m.cases_total }}</td>
    <td>{{ m.assertions_passed }} / {{ m.assertions_total }}
        ({{ "%.0f"|format((m.assertion_pass_rate or 0) * 100) }}%)</td>
    <td>{% if m.rubric_total %}{{ m.rubric_pass }} / {{ m.rubric_total }}{% else %}<span class="dim">—</span>{% endif %}</td>
    <td>{% if m.rubric_mean is not none %}{{ "%.2f"|format(m.rubric_mean) }}{% else %}<span class="dim">—</span>{% endif %}</td>
    <td>${{ "%.4f"|format(m.cost_usd) }}</td>
  </tr>
  {% endfor %}
</table>

<h2>Per-case breakdown</h2>
{% for case_id, info in (b.cases or {}).items()|sort %}
<h3><code>{{ case_id }}</code></h3>
<table>
  <tr><th>Model</th><th>Assertions</th><th>Rubric</th></tr>
  {% for model, stats in info.models.items()|sort %}
  <tr>
    <td><code>{{ model }}</code></td>
    <td>{{ stats.assertions_passed }} / {{ stats.assertions_total }}</td>
    <td>
      {% if stats.rubric_passed is true %}<span class="ok">✓</span>
      {% elif stats.rubric_passed is false %}<span class="bad">✗</span>
      {% else %}<span class="dim">—</span>{% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
{% endfor %}

</body>
</html>
